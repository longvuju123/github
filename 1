<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Cart</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: #f5f5f5;
}

/* HEADER */
.header {
  padding: 20px;
  background: #ddd;
  display: flex;
  justify-content: space-between;
}

/* CONTAINER */
.container {
  width: 1200px;
  margin: auto;
}

/* TITLE */
.title {
  margin: 20px 0;
  font-size: 24px;
  font-weight: bold;
}

/* CART LAYOUT */
.cart {
  display: flex;
  gap: 40px;
}

/* LEFT - LIST */
.cart-list {
  width: 70%;
}

.cart-item {
  display: flex;
  gap: 20px;
  background: #ccc;
  padding: 15px;
  margin-bottom: 15px;
}

/* IMAGE */
.img {
  width: 80px;
  height: 80px;
  background: #bbb;
}

/* INFO */
.info {
  flex: 1;
}

/* QUANTITY */
.quantity {
  display: flex;
  gap: 10px;
  margin-top: 10px;
}

.quantity button {
  width: 30px;
  height: 30px;
}

/* PRICE */
.price {
  width: 100px;
  text-align: right;
}

/* RIGHT - SUMMARY */
.summary {
  width: 30%;
  background: #ddd;
  padding: 20px;
}

.summary div {
  margin-bottom: 10px;
}

/* BUTTON */
.btn {
  padding: 10px;
  background: #999;
  text-align: center;
  margin-top: 10px;
}

/* MOBILE */
@media (max-width: 768px) {
  .container {
    width: 100%;
    padding: 0 16px;
  }

  .cart {
    flex-direction: column;
  }

  .cart-list, .summary {
    width: 100%;
  }
}
</style>

</head>

<body>

<!-- HEADER -->
<div class="header">
  <div>LOGO</div>
  <div>CART</div>
</div>

<div class="container">

  <div class="title">Giỏ hàng</div>

  <div class="cart">

    <!-- LEFT -->
    <div class="cart-list">

      <div class="cart-item">
        <div class="img"></div>

        <div class="info">
          <div>Tên sản phẩm</div>

          <div class="quantity">
            <button>-</button>
            <span>1</span>
            <button>+</button>
          </div>
        </div>

        <div class="price">2.500.000đ</div>
      </div>

      <div class="cart-item">
        <div class="img"></div>

        <div class="info">
          <div>Sản phẩm 2</div>

          <div class="quantity">
            <button>-</button>
            <span>1</span>
            <button>+</button>
          </div>
        </div>

        <div class="price">1.800.000đ</div>
      </div>

    </div>

    <!-- RIGHT -->
    <div class="summary">
      <div>Tạm tính: 4.300.000đ</div>
      <div>Phí ship: 30.000đ</div>
      <hr>
      <div><b>Tổng: 4.330.000đ</b></div>

      <div class="btn">Thanh toán</div>
    </div>

  </div>

</div>

</body>
</html>
